# ════════════════════════════════════════════
# VibeVault Android — .gitignore
# ════════════════════════════════════════════

# ── Gradle build outputs ──
.gradle/
build/
app/build/

# ── Keystore files — NEVER commit ──
*.jks
*.keystore

# ── Local config (SDK path, machine-specific) ──
local.properties

# ── Android Studio / IDE ──
*.iml
.idea/
.DS_Store
**/.DS_Store
*.swp
*~
.vscode/

# ── Captured output / profiling ──
captures/
.externalNativeBuild/
.cxx/
